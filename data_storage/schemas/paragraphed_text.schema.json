{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "lang", "context"],
  "additionalProperties": false,
  "properties": {
    "id":      { "type": "string" },
    "lang":    { "type": "string", "enum": ["fi", "en"] },
    "context": { "type": "string" },
    "image":   { "type": ["string", "null"] }
  }
}
