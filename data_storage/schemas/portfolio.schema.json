{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "lang", "title", "year_start", "status", "tech_stack"],
  "additionalProperties": false,
  "properties": {
    "id":         { "type": "string" },
    "lang":       { "type": "string", "enum": ["fi", "en"] },
    "title":      { "type": "string" },
    "year_start": { "type": "integer" },
    "year_end":   { "type": ["integer", "null"] },
    "status":     { "type": "string", "enum": ["completed", "ongoing", "archived"] },
    "tech_stack": { "type": "array", "items": { "type": "string" } },
    "repo_url":   { "type": ["string", "null"] },
    "demo_url":   { "type": ["string", "null"] },
    "image":      { "type": ["string", "null"] },
    "tags":       { "type": "array", "items": { "type": "string" } }
  }
}
