{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "lang", "institution", "degree", "location", "year_start"],
  "additionalProperties": false,
  "properties": {
    "id":              { "type": "string" },
    "lang":            { "type": "string", "enum": ["fi", "en"] },
    "institution":     { "type": "string" },
    "degree":          { "type": "string" },
    "major":           { "type": ["string", "null"] },
    "minor":           { "type": ["string", "null"] },
    "location":        { "type": "string" },
    "year_start":      { "type": "integer" },
    "year_end":        { "type": ["integer", "null"] },
    "additional_info": { "type": ["string", "null"] },
    "courses": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "required": ["name", "grade", "grading_system", "completion_year"],
        "additionalProperties": false,
        "properties": {
          "name":            { "type": "string" },
          "grade":           { "type": "string" },
          "grading_system":  { "type": "string" },
          "completion_year": { "type": "integer" },
          "tags":            { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
