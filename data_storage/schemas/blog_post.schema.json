{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "lang", "title", "date", "summary"],
  "additionalProperties": false,
  "properties": {
    "id":      { "type": "string" },
    "lang":    { "type": "string", "enum": ["fi", "en"] },
    "title":   { "type": "string" },
    "date":    { "type": "string" },
    "tags":    { "type": "array", "items": { "type": "string" } },
    "image":   { "type": ["string", "null"] },
    "summary": { "type": "string" }
  }
}
